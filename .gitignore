.coverage
.env

# Lock file (library - not committed)
uv.lock

# Other files
*.swp
*.swo
*.log
*.bak

# Virtual environments (non-hidden)
env/
venv/
/.scripts/
/.venv/

# Hidden helper files
.run.sh
.setup.sh
.setup.bat
.check_quality.py
